/dts-v1/;
/plugin/;

#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	compatible = "brcm,bcm2835", "brcm,bcm2711", "brcm,bcm2712";

	fragment@0 {
		target = <&spi0>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			/* Reserve all three chip-selects already in the boot overlay */
			num-cs = <3>;
			cs-gpios =
				<&gpio 8  GPIO_ACTIVE_LOW>,   /* I   -> CE0 */
				<&gpio 7  GPIO_ACTIVE_LOW>,   /* II  -> CE1 */
				<&gpio 16 GPIO_ACTIVE_LOW>;   /* III -> CS2 */

			ksz8851_i: ethernet@0 {
				compatible = "micrel,ks8851";
				reg = <0>;
				/*
				pinctrl-names = "default";
				pinctrl-0 = <&ksz8851_i_int_pins>;
				*/
				interrupt-parent = <&gpio>;
				interrupts = <6 IRQ_TYPE_EDGE_FALLING>;

				spi-max-frequency = <15000000>;
				status = "okay";
			};
		};
	};

	/* disable spidev on CE0 so the kernel can bind the LAN865x driver */
	fragment@1 {
		target = <&spidev0>;
		__overlay__ {
			status = "disabled";
		};
	};
	
	/* disable spidev on CE1 so the kernel can bind the LAN865x driver */
	fragment@2 {
		target = <&spidev1>;
		__overlay__ {
			status = "disabled";
		};
	};
	
	/* reserve GP5 */
	fragment@4 {
		target = <&gpio>;
		__overlay__ {
			gpio5_reserved: gpio5_reserved {
				gpio-hog;
				gpios = <5 GPIO_ACTIVE_HIGH>;
				input;
			};
		};
	};
	/* reserve GP12 */
	fragment@5 {
		target = <&gpio>;
		__overlay__ {
			gpio12_reserved: gpio12_reserved {
				gpio-hog;
				gpios = <12 GPIO_ACTIVE_HIGH>;
				input;
			};
		};
	};
	/* reserve GP17 */
	fragment@6 {
		target = <&gpio>;
		__overlay__ {
			gpio17_reserved: gpio17_reserved {
				gpio-hog;
				gpios = <17 GPIO_ACTIVE_HIGH>;
				input;
			};
		};
	};
	/* reserve GP27 */
	fragment@7 {
		target = <&gpio>;
		__overlay__ {
			gpio27_reserved: gpio27_reserved {
				gpio-hog;
				gpios = <27 GPIO_ACTIVE_HIGH>;
				input;
			};
		};
	};

	fragment@8 {
	target = <&i2c0>;
	__overlay__ {
		#address-cells = <1>;
		#size-cells = <0>;

		ee50: eeprom@50 {
			compatible = "atmel,24c32";
			reg = <0x50>;
			status = "okay";
		};
		
		ee60: eeprom@60 {
			compatible = "atmel,24c32";
			reg = <0x60>;
			status = "okay";
		};

		ee70: eeprom@70 {
			compatible = "atmel,24c32";
			reg = <0x70>;
			status = "okay";
		};
		
		ee74: eeprom@74 {
			compatible = "atmel,24c32";
			reg = <0x74>;
			status = "okay";
		};
		
		ee76: eeprom@76 {
			compatible = "atmel,24c32";
			reg = <0x76>;
			status = "okay";
		};
	};
};

fragment@9 {
	target = <&gpio>;
	__overlay__ {
		ksz8851_reset_high: ksz8851_reset_high {
			gpio-hog;
			gpios = <13 GPIO_ACTIVE_HIGH>;
			output-high;
			line-name = "ksz8851-reset";
		};
	};
};

	__overrides__ {
		speed   = <&ksz8851_i>, "spi-max-frequency:0";
	};
};
